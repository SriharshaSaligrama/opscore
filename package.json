{
    "name": "opscode",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "typecheck": "tsc --noEmit",
        "test": "dotenv -e .env.test -- vitest",
        "test:run": "dotenv -e .env.test -- vitest run",
        "lint": "eslint .",
        "migrate:dev": "dotenv -e .env -- prisma migrate dev",
        "migrate:prod": "dotenv -e .env.production -- prisma migrate deploy",
        "migrate:test": "dotenv -e .env.test -- prisma migrate deploy"
    },
    "dependencies": {
        "@prisma/client": "6.15.0",
        "bcrypt": "^6.0.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "dotenv": "^17.3.1",
        "lucide-react": "^0.577.0",
        "next": "16.1.6",
        "pg": "^8.18.0",
        "radix-ui": "^1.4.3",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "shadcn": "^4.0.8",
        "tailwind-merge": "^3.5.0",
        "tw-animate-css": "^1.4.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/react": "^16.3.2",
        "@types/bcrypt": "^6.0.0",
        "@types/node": "^20",
        "@types/pg": "^8.16.0",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@vitejs/plugin-react": "^5.1.4",
        "babel-plugin-react-compiler": "^1.0.0",
        "dotenv-cli": "^11.0.0",
        "eslint": "^9",
        "eslint-config-next": "16.1.6",
        "jsdom": "^28.1.0",
        "prisma": "6.15.0",
        "tailwindcss": "^4",
        "tsx": "^4.21.0",
        "typescript": "5.6.3",
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "^4.0.18"
    }
}