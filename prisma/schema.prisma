// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
    provider = "prisma-client-js"
    // output   = "../app/generated/prisma"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
    id           String   @id @default(uuid())
    name         String
    email        String   @unique
    passwordHash String
    createdAt    DateTime @default(now())

    memberships        Membership[]
    sessions           Session[]
    assets             Asset[]
    createdWorkOrders  WorkOrder[]           @relation("WorkOrderCreator")
    assignedWorkOrders WorkOrder[]           @relation("WorkOrderAssignee")
    domainEvents       DomainEvent[]
    sentInvitations    WorkspaceInvitation[] @relation("InvitationInviter")
}

model Workspace {
    id        String   @id @default(uuid())
    name      String
    createdAt DateTime @default(now())

    memberships     Membership[]
    sessions        Session[]
    assetCategories AssetCategory[]
    assets          Asset[]
    workOrders      WorkOrder[]
    domainEvents    DomainEvent[]
    invitations     WorkspaceInvitation[]
}

enum Role {
    OWNER
    ADMIN
    MANAGER
    TECHNICIAN
    VIEWER
}

model Membership {
    id          String   @id @default(uuid())
    userId      String
    workspaceId String
    role        Role
    createdAt   DateTime @default(now())

    user      User      @relation(fields: [userId], references: [id])
    workspace Workspace @relation(fields: [workspaceId], references: [id])

    @@unique([userId, workspaceId])
    @@index([workspaceId])
    @@index([userId])
    @@index([workspaceId, role])
}

model Session {
    id                String   @id @default(uuid())
    userId            String
    activeWorkspaceId String?
    expiresAt         DateTime
    createdAt         DateTime @default(now())

    user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
    activeWorkspace Workspace? @relation(fields: [activeWorkspaceId], references: [id], onDelete: SetNull)

    @@index([userId])
    @@index([activeWorkspaceId])
}

model AssetCategory {
    id          String   @id @default(uuid())
    workspaceId String
    name        String
    createdAt   DateTime @default(now())

    workspace Workspace @relation(fields: [workspaceId], references: [id])
    assets    Asset[]

    @@unique([workspaceId, name])
    @@index([workspaceId])
}

enum AssetStatus {
    ACTIVE
    INACTIVE
    MAINTENANCE
    RETIRED
}

model Asset {
    id String @id @default(uuid())

    name   String
    status AssetStatus @default(ACTIVE)

    workspaceId String
    categoryId  String
    createdBy   String

    isDeleted Boolean  @default(false)
    createdAt DateTime @default(now())

    workspace  Workspace     @relation(fields: [workspaceId], references: [id])
    category   AssetCategory @relation(fields: [categoryId], references: [id])
    creator    User          @relation(fields: [createdBy], references: [id])
    workOrders WorkOrder[]

    @@index([workspaceId])
    @@index([categoryId])
}

enum WorkOrderStatus {
    OPEN
    ASSIGNED
    IN_PROGRESS
    COMPLETED
    CLOSED
}

enum WorkOrderPriority {
    LOW
    MEDIUM
    HIGH
    CRITICAL
}

model WorkOrder {
    id String @id @default(cuid())

    workspaceId String
    workspace   Workspace @relation(fields: [workspaceId], references: [id])

    assetId String
    asset   Asset  @relation(fields: [assetId], references: [id])

    assignedTo String?
    assignee   User?   @relation("WorkOrderAssignee", fields: [assignedTo], references: [id])

    createdBy String
    creator   User   @relation("WorkOrderCreator", fields: [createdBy], references: [id])

    status   WorkOrderStatus   @default(OPEN)
    priority WorkOrderPriority @default(MEDIUM)

    description String?

    isDeleted Boolean @default(false)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([workspaceId])
    @@index([workspaceId, status])
    @@index([workspaceId, assetId])
    @@index([workspaceId, assignedTo])
    @@index([workspaceId, priority])
}

enum DomainEntityType {
    USER
    WORKSPACE
    MEMBERSHIP
    ASSET
    ASSET_CATEGORY
    WORK_ORDER
    WORKSPACE_INVITATION
}

model DomainEvent {
    id String @id @default(cuid())

    workspaceId String
    workspace   Workspace @relation(fields: [workspaceId], references: [id])

    entityType DomainEntityType
    entityId   String // ID of the entity

    actorId String // user who performed the action
    actor   User   @relation(fields: [actorId], references: [id])

    type String // event type

    message  String? // optional human-readable text
    metadata Json? // structured details (optional)

    createdAt DateTime @default(now())

    @@index([workspaceId])
    @@index([entityType, entityId])
}

model WorkspaceInvitation {
    id String @id @default(cuid())

    workspaceId String
    workspace   Workspace @relation(fields: [workspaceId], references: [id])

    email String
    role  Role

    token      String    @unique
    expiresAt  DateTime
    acceptedAt DateTime?

    invitedBy String
    inviter   User   @relation("InvitationInviter", fields: [invitedBy], references: [id])

    createdAt DateTime @default(now())

    @@index([workspaceId])
    @@index([email])
    @@index([token])
}
